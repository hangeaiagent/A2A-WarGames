# ============================================================
# War-Games Backend — Environment Variables
# Copy this file to .env and fill in the values.
# NEVER commit .env to version control.
# ============================================================

# --- LLM Configuration (required) ---
# Base URL for your OpenAI-compatible LLM endpoint
LLM_BASE_URL=https://your-llm-proxy/v1
# API key for the LLM endpoint
LLM_API_KEY=your-api-key-here
# Default model used for stakeholder agents
LLM_DEFAULT_MODEL=gpt-4o
# Comma-separated list of models for the agent council (one per agent)
LLM_COUNCIL_MODELS=gpt-4o,gpt-4o,gpt-4o
# Model used for the chairman / moderator
LLM_CHAIRMAN_MODEL=gpt-4o

# --- App ---
APP_HOST=0.0.0.0
APP_PORT=8000
# Set to true only in development - exposes tracebacks
DEBUG=false

# --- Database ---
# SQLite (dev): sqlite:///./wargame.db
# PostgreSQL (prod): postgresql+psycopg2://user:pass@host:5432/dbname
DATABASE_URL=sqlite:///./wargame.db

# --- CORS ---
# Comma-separated list of allowed origins, or * for development
ALLOWED_ORIGINS=http://localhost:5173

# --- Supabase (auth + RLS) ---
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_KEY=your-service-role-key
SUPABASE_JWT_SECRET=your-jwt-secret
